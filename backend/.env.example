APP_NAME=AI Engineering Copilot
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=true

API_PREFIX=/api/v1

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

STORAGE_DIR=storage
MAX_UPLOAD_SIZE_MB=50
MAX_EXTRACTED_SIZE_MB=200
MAX_PROJECT_FILES=3000  

MAX_SINGLE_FILE_SIZE_MB=2
FILE_PREVIEW_LIMIT=200

CHUNK_PREVIEW_LIMIT=50
DEFAULT_CHUNK_SIZE_LINES=80
DEFAULT_CHUNK_OVERLAP_LINES=12

POSTGRES_USER=ai_copilot
POSTGRES_PASSWORD=ai_copilot_password
POSTGRES_DB=ai_copilot
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://ai_copilot:ai_copilot_password@localhost:5432/ai_copilot
DATABASE_ECHO=false

DATABASE_SCHEMA=ai_copilot

EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=16
SEARCH_PREVIEW_CHARACTER_LIMIT=900

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:3b
OLLAMA_TIMEOUT_SECONDS=120
LLM_TEMPERATURE=0.1

RAG_DEFAULT_TOP_K=5
RAG_MAX_CONTEXT_CHARACTERS=12000
RAG_CONTEXT_CHUNK_PREVIEW_LIMIT=900